rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isMaster(currentMasterEmail) {
      return isSignedIn() && request.auth.token.email == currentMasterEmail && request.auth.token.email_verified == true;
    }

    // System Config
    match /system_config/master {
      // Allow everyone to read the master email so the app can identify the admin
      allow read: if true;
      
      // Only the current master can update the master email
      // Bootstrap phase: if the doc doesn't exist, we might need a way to create it.
      // But we will assume the dev (us) or the bootstrap email sets it.
      allow write: if isMaster(resource.data.email) || 
                   (resource == null && request.auth.token.email == 'auricleciorocha30@gmail.com');
    }
  }
}
