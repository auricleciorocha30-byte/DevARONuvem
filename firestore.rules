rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidEmail(email) {
      return email is string && email.size() < 256 && email.matches('.+@.+\\..+');
    }

    // System Config
    match /system_config/master {
      allow read: if true;
      allow write: if isSignedIn() && (
        // Allow bootstrap or existing master (primary or secondary)
        (resource == null && request.auth.token.email == 'auricleciorocha30@gmail.com') ||
        (resource != null && (
          request.auth.token.email == resource.data.email || 
          (resource.data.keys().hasAll(['secondaryEmail']) && request.auth.token.email == resource.data.secondaryEmail)
        ))
      ) && 
      isValidEmail(request.resource.data.email) &&
      (!request.resource.data.keys().hasAll(['secondaryEmail']) || isValidEmail(request.resource.data.secondaryEmail));
    }
  }
}
