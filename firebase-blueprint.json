{
  "entities": {
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global settings for the ecosystem",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "Primary master administration email" },
        "secondaryEmail": { "type": "string", "format": "email", "description": "Secondary/Recovery master administration email" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "system_config/master": {
      "schema": "SystemConfig",
      "description": "Root configuration document"
    }
  }
}
